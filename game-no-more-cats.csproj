<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>game_no_more_cats</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="OpenTK" Version="4.9.4" />
      <PackageReference Include="OpenTK.Windowing.Desktop" Version="4.9.4" />
      <PackageReference Include="SimplexNoise" Version="2.0.0" />
      <PackageReference Include="StbImageSharp" Version="2.30.15" />
    </ItemGroup>

    <ItemGroup>
      <Content Include="Textures/**" CopyToOutputDirectory="PreserveNewest" />
      <Content Include="Shaders/**" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>

</Project>
